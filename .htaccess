<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Protect sensitive files
    RewriteRule ^\.env - [F,L]
    RewriteRule ^composer\.(json|lock) - [F,L]
    RewriteRule ^package(-lock)?\.json - [F,L]
    RewriteRule ^yaml?\.lock - [F,L]
    RewriteRule ^\.git - [F,L]
    RewriteRule ^sql/ - [F,L,NC]
    RewriteRule ^vendor/ - [F,L,NC]

    # Block access to PHP files in specific directories
    RewriteRule ^includes/.*\.php$ - [F,L,NC]
    RewriteRule ^components/.*\.php$ - [F,L,NC]

    # Prevent directory listing
    Options -Indexes

    # Protect admin login against brute force via IP whitelist (optional)
    # RewriteCond %{REQUEST_URI} ^/admin/login\.php [NC]
    # RewriteCond %{REMOTE_ADDR} !^192\.168\.1\. [NC]
    # RewriteRule ^ - [F,L]
</IfModule>

<IfModule mod_headers.c>
    # Security Headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(self), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://code.jquery.com https://cdnjs.cloudflare.com 'unsafe-inline' 'unsafe-eval'; style-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https: data:; connect-src 'self'; frame-src 'none'; object-src 'none'"
</IfModule>

<IfModule mod_expires.c>
    # Cache static assets
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

<IfModule mod_deflate.c>
    # Compress output
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# PHP Security Settings
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log ./storage/logs/php-error.log
    php_value session.cookie_httponly 1
    php_value session.cookie_secure 1
    php_value session.cookie_samesite "Strict"
    php_value session.use_only_cookies 1
    php_value session.use_strict_mode 1
    php_value session.gc_maxlifetime 7200
    php_value session.sid_length 48
    php_value session.sid_bits_per_character 6
</IfModule>
